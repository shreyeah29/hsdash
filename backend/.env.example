# Local Docker Postgres (see README): docker run --name hsdash-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=hsdash -p 5432:5432 -d postgres:16
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hsdash?schema=public
PORT=4000
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
SEED_DEFAULT_PASSWORD=ChangeMe123!
COOKIE_SECURE=false

# Set true on Render temporarily to allow POST /auth/demo (password-free). Disable for production.
DEMO_LOGIN=false


DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
PORT=4000
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
# Must match the coordinator's login email (defaults to seeded Emmanuel).
CALENDAR_COORDINATOR_EMAIL=emmanuel@wedding.local
SEED_DEFAULT_PASSWORD=ChangeMe123!
COOKIE_SECURE=false

# Set true on Render temporarily to allow POST /auth/demo (password-free). Disable for production.
DEMO_LOGIN=false


// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COORDINATOR
  EDITOR
}

enum Team {
  PHOTO_TEAM
  CINEMATIC_TEAM
  TRADITIONAL_TEAM
  ALBUM_TEAM
  COORDINATOR_TEAM
}

enum TaskType {
  PREVIEW_PHOTOS
  SNEAK_PEEK_PHOTOS
  FULL_PHOTOS
  FULL_SET_PHOTOS
  CINEMATIC_VIDEO
  CINEMATIC_HIGHLIGHT
  REELS
  TRADITIONAL_VIDEO
  ALBUM_DESIGN
  ALBUM_PRINT
  DATA_COPY
}

enum TaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
}

enum LeadStatus {
  NEW
  CONTACTED
  NEGOTIATION
  CONFIRMED
  LOST
  ARCHIVED
}

enum LeadSource {
  WEBSITE
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  REFERRAL
  MANUAL
  GOOGLE
}

enum LeadEventType {
  WEDDING
  OTHER
}

enum LeadActivityKind {
  CREATED
  STATUS_CHANGED
  NOTE_ADDED
  ASSIGNED
  CONVERTED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(EDITOR)
  team         Team?
  designation  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  assignedTasks        Task[]             @relation("TaskAssignee")
  tasksAssignedBy      Task[]             @relation("TaskAssignedBy")
  taskActivities       TaskActivity[]     @relation("ActivityActor")
  shootCalendarEntries ShootCalendarEntry[]
  notifications        UserNotification[]
  eventsCreated        Event[]            @relation("EventCreatedBy")
  leadsAssigned        Lead[]             @relation("LeadAssignee")
  leadNotes            LeadNote[]         @relation("LeadNoteAuthor")
  leadActivities       LeadActivity[]     @relation("LeadActivityActor")

  @@index([role])
  @@index([team])
  @@index([isActive])
}

model Event {
  id                      String   @id @default(cuid())
  clientName              String
  eventDate               DateTime
  venue                   String   @default("")
  shootTime               String   @default("")
  notes                   String   @default("")
  postProductionStarted   Boolean  @default(false)
  createdById             String?
  createdBy               User?    @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt               DateTime @default(now())

  tasks              Task[]
  shootCalendarEntry ShootCalendarEntry?

  @@index([createdById])
  @@index([eventDate])
}

model ShootCalendarEntry {
  id           String   @id @default(cuid())
  day          DateTime

  clientName   String
  brideName    String   @default("")
  groomName    String   @default("")
  phoneNumber  String   @default("")
  clientType   String   @default("")
  clientContact String  @default("")
  city         String   @default("")
  eventName    String   @default("")
  venue        String   @default("")
  startTime    String   @default("")
  endTime      String   @default("")
  muhuruthamTime String @default("")
  photoTeam    String   @default("")
  videoTeam    String   @default("")
  addons       String   @default("")

  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  eventId String? @unique
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([day])
}

model Task {
  id           String       @id @default(cuid())
  eventId      String
  taskType     TaskType
  assignedTeam Team
  deadline     DateTime
  status       TaskStatus   @default(PENDING)
  priority     TaskPriority @default(LOW)
  createdAt    DateTime     @default(now())

  assignedToId String?
  assignedTo   User? @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  assignedById String?
  assignedBy   User? @relation("TaskAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  event        Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  activities   TaskActivity[]
  notifications UserNotification[]

  @@index([eventId])
  @@index([assignedTeam])
  @@index([assignedToId])
  @@index([assignedById])
  @@index([status])
  @@index([priority])
  @@index([deadline])
}

model TaskActivity {
  id             String       @id @default(cuid())
  taskId         String
  actorUserId    String?
  previousStatus TaskStatus?
  newStatus      TaskStatus
  createdAt      DateTime     @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User? @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([createdAt])
  @@index([actorUserId])
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  taskId    String?
  title     String
  body      String   @default("")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model Lead {
  id                String        @id @default(cuid())
  status            LeadStatus    @default(NEW)
  source            LeadSource    @default(WEBSITE)
  eventType         LeadEventType @default(WEDDING)
  name              String        @default("")
  phoneNumber       String
  phoneNormalized   String
  eventDate         DateTime
  eventLocation     String        @default("")
  brideName         String        @default("")
  groomName         String        @default("")
  clientName        String        @default("")
  message           String        @default("")
  assignedToId      String?
  assignedTo        User?         @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  convertedEntryId  String?
  convertedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  notes      LeadNote[]
  activities LeadActivity[]

  @@index([status])
  @@index([source])
  @@index([phoneNormalized])
  @@index([eventDate])
  @@index([createdAt])
  @@index([assignedToId])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content   String
  authorId  String
  author    User     @relation("LeadNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}

model LeadActivity {
  id           String           @id @default(cuid())
  leadId       String
  lead         Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  kind         LeadActivityKind
  message      String           @default("")
  previousStatus LeadStatus?
  newStatus    LeadStatus?
  actorUserId  String?
  actor        User?            @relation("LeadActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())

  @@index([leadId])
  @@index([createdAt])
}

model AdminCalendarNote {
  id        String   @id @default(cuid())
  day       DateTime
  title     String?
  body      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([day])
}
